{
  "manifest_version": 3,
  "name": "Repo Analyzer",
  "version": "4.3",
  "description": "Analyze GitHub repos - no API needed, works locally",
  "permissions": ["activeTab", "tabs"],
  "host_permissions": ["https://github.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.svg",
      "48": "icon.svg",
      "128": "icon.svg"
    }
  },
  "content_scripts": [{
    "matches": ["https://github.com/*"],
    "js": ["content.js"]
  }]
}
