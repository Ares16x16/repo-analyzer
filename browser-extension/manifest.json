{
  "manifest_version": 3,
  "name": "Repo Analyzer",
  "version": "4.3",
  "description": "Analyze GitHub repos - no API needed, works locally",
  "permissions": ["activeTab"],
  "host_permissions": ["https://github.com/*"],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png"
    }
  },
  "content_scripts": [{
    "matches": ["https://github.com/*"],
    "js": ["content.js"]
  }]
}
